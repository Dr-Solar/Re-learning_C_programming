Question 1:Get a number from user and see if the number equals to 50 .If yes the print success otherwise print Failure

 #include <stdio.h>
int main() {
    int x;
    scanf("%d",&x);
    if(x==50)
    {
        printf("Success");
    }
    else
     printf("Failure");
    return 0;
}

