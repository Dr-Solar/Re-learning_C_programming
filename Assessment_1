//Question-22:Get a three digit number from user.If sum of digits is less than 10 print sum.Otherwise add the digits of the sum ,if that is less than 10 then print sum 
if not then do it again until we get a single digit number as result

#include <stdio.h>
int main() {
    int w,x,y,z;
    scanf("%d",&w);
    x=w/100+(w%100)/10+w%10;//1or0
    printf("1:%d\n",x);
    y=(x/10+x%10);//1or0
    printf("2:%d\n",y);
    z=(y/10+y%10)*(1-(y<10))*(1-(x<10));
    printf("3:%d\n",z);
    y=y*(1-(x<10));
    y=z*(z<10)+y*(y<10)+x*(x<=10);
    printf("Result = %d\n",y);
    return 0;
}


