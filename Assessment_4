Question 9:Write a loop program to print sum of two digit odd numbers whose sum of digits is 7

#include<stdio.h>
int main(){
    int x,y,z,sum;
    x=9;
    sum=0;
    loop:if(x<100){
        x=x+2;
        y=x/10;
        z=x%10;
        y=y+z;
        if(y==7){
            sum=sum+x;
            printf("1:%d\n",sum);
        }
        else 
        y=0;
        goto loop;
    }
    printf("2:%d\n",sum);
    return 0;
}

