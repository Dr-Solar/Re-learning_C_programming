Question 7:Write a loop program to print two digit odd numbers , whose sum of digits is 7

#include<stdio.h>
int main(){
    int x,y,z;
    for(x=10;x<100;x++){
        y=x%2;
        z=x/10+x%10;
        if(y==1){
            if(z==7){
                printf("%d\n",x);
            }
        }
    }
    return 0;
}

